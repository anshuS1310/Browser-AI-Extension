{
  "manifest_version": 3,
  "name": "Browser AI Extension",
  "version": "3.0",
  "permissions": ["sidePanel", "scripting", "activeTab", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "Open AI Scanner" },
  "icons": { "128": "icon.png" },
  "side_panel": { "default_path": "sidepanel.html" }
}